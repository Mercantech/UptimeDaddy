# Kopiér til .env i repo-roden og sæt stærke værdier.
# docker compose --env-file .env up --build

# VIGTIGT — PostgreSQL + Docker-volume:
# POSTGRES_PASSWORD bruges KUN første gang volumenet (pgdata) oprettes.
# Skifter du kodeord i .env bagefter, får du stadig FATAL: password authentication failed (28P01),
# og service-account / API kan ikke starte → Ruby fejler med "name resolution" på service-account.
# Løsning: (1) Sæt kodeord til det samme som ved første opstart, ELLER (2) nulstil DB-brugeren:
#   docker compose exec postgres psql -U uptimedaddy -d uptimedaddy -c "ALTER USER uptimedaddy PASSWORD 'dit_nye_kodeord';"
#   (brug samme værdi som POSTGRES_PASSWORD i .env), ELLER (3) slet volumenet (sletter data):
#   docker compose down -v
# Brug gerne quotes hvis kodeord har specialtegn: POSTGRES_PASSWORD="dit!kodeord"

POSTGRES_PASSWORD=changeme_db_password
JWT_SECRET=changeme_use_a_long_random_string_for_hs256

# Ruby http_requester: logger ind mod Go /accounts/login med disse felter.
# De skal matche en EKSISTERENDE bruger (email + adgangskode som ved registrering) — ellers får du 401 og ingen websites.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme_admin_password

# --- Host-porte (fællesserver / port-kollisioner) ---
# Standardværdier matcher docker-compose.yml defaults. Sæt unikke værdier pr. deployment.
# Postgres: standard 35432 på host → undgår konflikt med en anden instans på 5432.
# POSTGRES_PUBLISH_PORT=35432
# MQTT_PUBLISH_PORT=11883
# API_PUBLISH_PORT=8080
# SERVICE_ACCOUNT_PUBLISH_PORT=6969
# FRONTEND_PUBLISH_PORT=5173

# Frontend build (browser skal kunne nå URL’erne)
# Lokal Docker: http://localhost:... er fint. Cloudflare / offentligt domæne: brug ALTID https://
# VITE_ACCOUNTS_URL=https://acc-uptimedaddy.mercantec.tech/accounts
# VITE_API_URL=https://api-uptimedaddy.mercantec.tech/api

# --- Cloudflare Tunnel / HTTPS / CORS ---
# CORS_ALLOWED_ORIGINS skal matche den PRÆCISE Origin browseren sender — samme subdomæne som hvor SPA’en åbnes.
# Fx åbner du https://uptimedaddy.mercantec.tech så skal det være præcis det (IKKE https://uptime... hvis det er et andet hostnavn).
# Kommasepareret uden mellemrum efter komma. Ingen sti, ingen afsluttende /
# Eksempel:
# CORS_ALLOWED_ORIGINS=https://uptimedaddy.mercantec.tech
