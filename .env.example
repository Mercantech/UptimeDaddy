# Kopiér til .env i repo-roden og sæt stærke værdier.
# Dokploy/prod:  docker compose up -d --build
# Lokal dev:     docker compose -f docker-compose.yml -f docker-compose.local.yml up --build

# VIGTIGT — PostgreSQL + Docker-volume:
# POSTGRES_PASSWORD bruges KUN første gang volumenet (pgdata) oprettes.
# Skifter du kodeord i .env bagefter, får du stadig FATAL: password authentication failed (28P01),
# og service-account / API kan ikke starte → Ruby fejler med "name resolution" på service-account.
# Løsning: (1) Sæt kodeord til det samme som ved første opstart, ELLER (2) nulstil DB-brugeren:
#   docker compose exec postgres psql -U uptimedaddy -d uptimedaddy -c "ALTER USER uptimedaddy PASSWORD 'dit_nye_kodeord';"
#   (brug samme værdi som POSTGRES_PASSWORD i .env), ELLER (3) slet volumenet (sletter data):
#   docker compose down -v
# Brug gerne quotes hvis kodeord har specialtegn: POSTGRES_PASSWORD="dit!kodeord"

POSTGRES_PASSWORD=changeme_db_password
JWT_SECRET=changeme_use_a_long_random_string_for_hs256

# Discord bot (discord-worker container). Opret en bot i Discord Developer Portal og indsæt token.
# Se docker-compose service "discord-worker" og Backend docs: docs/api.md (Discord).
DISCORD_BOT_TOKEN=
# Valgfri: Discord guild-id (snowflake) for at registrere slash-kommandoer kun på den server (øjeblikkeligt).
# Udelades: kommandoer registreres globalt (Discord kan bruge op til ~1 time om at vise dem overalt).
# DISCORD_SLASH_GUILD_ID=

# Valgfri: custom Discord-emoji som <:alias:id> (bot skal være på samme server som emoji).
# Standard matcher projekt-emoji; sæt til "-" for at slå et tag fra.
# DISCORD_EMOJI_LOGO=<:logo:1495125363968442379>
# DISCORD_EMOJI_FAVICON=<:favicon:1495132715660607699>
# DISCORD_EMOJI_LOGIN=<:loginImage:1495125413330948289>

# Ruby http_requester: logger ind mod Go /accounts/login med disse felter.
# De skal matche en EKSISTERENDE bruger (email + adgangskode som ved registrering) — ellers får du 401 og ingen websites.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme_admin_password

# --- Traefik / Dokploy (prod) — subdomæner under mercantec.tech ---
# Cloudflare DNS + tunnel skal pege på Dokploy; Traefik router Host() matcher disse værdier.
FRONTEND_DOMAIN=uptimedaddy.mercantec.tech
API_DOMAIN=api-uptimedaddy.mercantec.tech
ACCOUNTS_DOMAIN=acc-uptimedaddy.mercantec.tech

# Frontend build (browser kalder API/accounts via HTTPS på domænerne ovenfor)
# VITE_* kan overskrives; defaults i docker-compose.yml matcher ACCOUNTS_DOMAIN / API_DOMAIN.
# VITE_ACCOUNTS_URL=https://acc-uptimedaddy.mercantec.tech/accounts
# VITE_API_URL=https://api-uptimedaddy.mercantec.tech/api

# Valgfrit: unikt id pr. deploy så Docker ikke genbruger en gammel frontend-build (fx git commit: VITE_BUILD_ID=abc1234)
# VITE_BUILD_ID=

# Valgfrit: auto-opdater dashboard (tabeller, kort, uptime-striber) i ms. Standard 30000. Minimum 5000 håndhæves i koden.
# VITE_DASHBOARD_POLL_MS=30000

# CORS: præcis Origin fra browseren (samme subdomæne som SPA — typisk FRONTEND_DOMAIN med https://)
# CORS_ALLOWED_ORIGINS=https://uptimedaddy.mercantec.tech

# --- Lokal udvikling (docker-compose.local.yml) — host-porte ---
# POSTGRES_PUBLISH_PORT=35432
# MQTT_PUBLISH_PORT=11883
# API_PUBLISH_PORT=8080
# SERVICE_ACCOUNT_PUBLISH_PORT=6969
# FRONTEND_PUBLISH_PORT=5173
# DISCORD_WORKER_PUBLISH_PORT=6970
#
# Lokal .env til browser-build:
# VITE_ACCOUNTS_URL=http://localhost:6969/accounts
# VITE_API_URL=http://localhost:8080/api
# CORS_ALLOWED_ORIGINS=http://localhost:5173
